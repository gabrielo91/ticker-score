# DarkScore environment variables (copy to .env and fill in)

# PostgreSQL connection string (matches docker/docker-compose.yml defaults)
DATABASE_URL=postgres://darkscore:darkscore@localhost:5432/darkscore

# Redis connection string (matches docker/docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Twelve Data API key (REQUIRED for the default data source).
# Free tier: https://twelvedata.com/dashboard — 800 calls/day, 8 calls/min.
TWELVEDATA_API_KEY=

# Finnhub API token (optional — registered as an alternative provider when set).
# Free tier: https://finnhub.io/dashboard — 60 calls/min, 30 calls/sec.
FINNHUB_API_KEY=

